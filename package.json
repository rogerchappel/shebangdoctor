{
  "name": "shebangdoctor",
  "version": "0.1.0",
  "description": "Audit and fix script shebang, executable bit, CRLF, and interpreter portability issues.",
  "type": "module",
  "bin": {
    "shebangdoctor": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "shebang",
    "scripts",
    "ci",
    "agentic-workflows"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/shebangdoctor.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/shebangdoctor/issues"
  },
  "homepage": "https://github.com/rogerchappel/shebangdoctor#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
